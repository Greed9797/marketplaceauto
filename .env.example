# Production operational envs
# Required in Vercel Production. Connector app/API credentials are NOT configured here.

# Database / Supabase Postgres
# Shared Supabase production must use ?schema=w3ads to avoid public/pulmao/saas collisions.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/adstart_w3?schema=w3ads"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/adstart_w3?schema=w3ads"
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Auth / public URL
NEXTAUTH_SECRET=""
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="false"
# Auth cannot be disabled in production. Local QA can use DEV_AUTH_BYPASS_EMAIL
# after running `npm run db:seed`.
AUTH_DISABLED="false"
DEV_AUTH_BYPASS_EMAIL=""
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# Official "W3 Ads app" connector defaults — shared across workspaces.
# When set, the connector settings form pre-fills these and OAuth/sync works
# without a per-workspace DB config. Per-workspace ConnectorProviderConfig wins.
# Shared Google OAuth client above is reused for both Google Ads and GA4.
GOOGLE_ADS_DEVELOPER_TOKEN=""
GOOGLE_ADS_REDIRECT_URI="https://w3ads.vercel.app/api/connectors/google-ads/callback"
GOOGLE_ANALYTICS_REDIRECT_URI="https://w3ads.vercel.app/api/connectors/google-analytics/callback"
# Optional Google Ads overrides:
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=""
# GOOGLE_ADS_SCOPES="https://www.googleapis.com/auth/adwords"
# GOOGLE_ADS_API_VERSION="v24"
# GOOGLE_ANALYTICS_SCOPES="https://www.googleapis.com/auth/analytics.readonly"
# Meta system-user access token (account id + name stay manual per connection):
META_ACCESS_TOKEN=""
# META_REDIRECT_URI=""
# META_API_VERSION="v25.0"

# Transactional email
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Adstart W3 <no-reply@w3educacao.com.br>"

# Connector secrets
# Meta, Google Ads, Shopify, Nuvemshop and ecommerce API credentials are configured
# in /connectors/settings and stored in Supabase Vault/KMS, not in env vars.
# TOKEN_ENCRYPTION_KEY is optional legacy fallback only for old AES-encrypted rows.
TOKEN_ENCRYPTION_KEY=""

# Vercel Cron secret — authorizes /api/cron/* invocations. Vercel injects
# `Authorization: Bearer ${CRON_SECRET}` automatically for paths declared in vercel.json.
CRON_SECRET=""

# Optional: gate the DETAILED /api/health breakdown behind a bearer token. When
# unset, /api/health stays public but returns only { ok, service, timestamp }.
# Set it and call with `Authorization: Bearer ${HEALTH_CHECK_TOKEN}` to see the
# full vault/redis/inngest/db checks.
HEALTH_CHECK_TOKEN=""

# Nuvemshop — shared "W3 Ads" Partners app credentials. When set, ALL workspaces
# can connect Nuvemshop without provisioning their own app. Optional — per-workspace
# ProviderConfig still takes precedence if present.
NUVEMSHOP_CLIENT_ID=""
NUVEMSHOP_CLIENT_SECRET=""
# Optional overrides (defaults work for production):
# NUVEMSHOP_REDIRECT_URI=""  # default: ${origin}/api/connectors/nuvemshop/callback
# NUVEMSHOP_API_BASE_URL=""  # default: https://api.nuvemshop.com.br/v1

# Redis + Jobs / Rate limiting
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Observability
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
POSTHOG_API_KEY=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ─── W3-Marketplace ────────────────────────────────────────────────────────
# Marketplace-first mode (default true): hides the paid-traffic connectors
# (Meta/Google Ads, GA4) from the UI and from the dashboard's default traffic
# aggregation. Set to "false" to re-enable them — the code/enum stay intact.
MARKETPLACE_FIRST="true"

# Mercado Livre — shared "W3 app" connector defaults (optional; per-workspace
# ProviderConfig in /connectors/settings takes precedence). Without these, each
# workspace must provide its own clientId/clientSecret.
ML_CLIENT_ID=""
ML_CLIENT_SECRET=""
ML_REDIRECT_URI=""           # default: ${origin}/api/connectors/mercado-livre/callback
                             # ATENÇÃO: compartilhada com o publisher; se apontar para
                             # /api/auth/ml/callback, o conector a ignora.
# ML_CONNECTOR_REDIRECT_URI="" # override exclusivo do conector (vence ML_REDIRECT_URI)
# ML_API_BASE_URL=""         # default: https://api.mercadolibre.com

# Mercado Livre — app do PUBLISHER (fluxo /api/auth/ml/*, app ML separado)
# ML_APP_ID=""
# ML_SECRET=""

# Shopee — shared "W3 app" connector defaults (optional). partner_key is the
# HMAC signing secret; keep it out of source/logs. Per-workspace config wins.
SHOPEE_PARTNER_ID=""
SHOPEE_PARTNER_KEY=""
SHOPEE_REDIRECT_URI=""       # default: ${origin}/api/connectors/shopee/callback
                             # ATENÇÃO: compartilhada com o publisher; se apontar para
                             # /api/auth/shopee/callback, o conector a ignora.
# SHOPEE_CONNECTOR_REDIRECT_URI="" # override exclusivo do conector
# SHOPEE_HOST=""             # default: https://partner.shopeemobile.com
                             # sandbox: https://partner.test-stable.shopeemobile.com
# SHOPEE_SANDBOX=""          # "true" liga o host sandbox no fluxo do publisher
# SHOPEE_SANDBOX_HOST=""     # override do host sandbox do publisher

# Publisher — geração de copy com IA (opcional)
# GEMINI_API_KEY=""

# Copiloto-chat — MiniMax M3 (multimodal + tool-calling). Obrigatório p/ o chat.
# MINIMAX_API_KEY=""
# MINIMAX_BASE_URL=""   # default https://api.minimax.io/v1

# Webhook Nuvemshop — só para debug local; NUNCA "true" em produção
# NUVEMSHOP_ALLOW_UNSIGNED_PROBE=""
